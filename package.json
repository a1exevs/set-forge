{
  "name": "@set-forge/workspace",
  "private": true,
  "description": "Set Forge monorepo (workspaces: client, server).",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": "22.20.0",
    "npm": "10.9.3"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "npm run dev -w @set-forge/client",
    "build": "npm run build -w @set-forge/client",
    "preview": "npm run preview -w @set-forge/client",
    "check-deps": "npm run check-deps -w @set-forge/client",
    "upgrade-deps": "npm run upgrade-deps -w @set-forge/client",
    "format": "npm run format -w @set-forge/client",
    "format:check": "npm run format:check -w @set-forge/client",
    "format:root": "prettier --config client/.prettierrc.cjs --write \"scripts/**/*.{ts,tsx}\"",
    "format:root:check": "prettier --config client/.prettierrc.cjs --check \"scripts/**/*.{ts,tsx}\"",
    "lint": "npm run lint -w @set-forge/client",
    "lint:fix": "npm run lint:fix -w @set-forge/client",
    "test:unit": "npm run test:unit -w @set-forge/client",
    "test:unit-cov": "npm run test:unit-cov -w @set-forge/client",
    "test:snap": "npm run test:snap -w @set-forge/client",
    "test:snap-cov": "npm run test:snap-cov -w @set-forge/client",
    "test:snap-update": "npm run test:snap-update -w @set-forge/client",
    "test:e2e": "npm run test:e2e -w @set-forge/client",
    "test": "npm run test -w @set-forge/client",
    "storybook": "npm run storybook -w @set-forge/client",
    "build-storybook": "npm run build-storybook -w @set-forge/client",
    "chromatic": "npm run chromatic -w @set-forge/client",
    "docs": "npm run docs -w @set-forge/client",
    "e2e:install": "npm run e2e:install -w @set-forge/client",
    "version:major": "ts-node -P scripts/tsconfig.json scripts/increase-version.ts major",
    "version:minor": "ts-node -P scripts/tsconfig.json scripts/increase-version.ts minor",
    "version:patch": "ts-node -P scripts/tsconfig.json scripts/increase-version.ts patch",
    "update-version:major": "./scripts/update-version.sh major",
    "update-version:minor": "./scripts/update-version.sh minor",
    "update-version:patch": "./scripts/update-version.sh patch"
  },
  "devDependencies": {
    "husky": "8.0.3",
    "lint-staged": "13.3.0",
    "prettier": "3.5.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
